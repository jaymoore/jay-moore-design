# Password gating the /work/spm-lifecycle case study (HTTP Basic Auth via
# middleware.ts). Copy this file to .env.local for local dev and set the
# value to whatever password you want to share with reviewers.
#
# Production: set this in the Vercel / Cloudflare deployment dashboard.
# If unset, the middleware falls back to the password "preview" so the
# route doesn't 500 — but you should set a real value before sharing the
# URL.

CASE_STUDY_PASSWORD=
